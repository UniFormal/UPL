{
  "scopeName": "source.upl",
  "patterns": [
    {
      "match": "//.*",
      "name": "comment.line.double-slash "
    },
    {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double",
      "patterns": [{
        "name": "constant.character.escape",
        "match": "\\\\."
      }]
    },
    {
      "match": "\\d+",
      "name": "constant.numeric"
    },
    {
      "match": "->|==|=>|forall|exists|\\|-|\\+|\\*|\\-|\\.|\\&|\\!|<|>|\\|",
      "name": "keyword.operator.upl"
    },
    {
      "match": "=|:|#",
      "name": "punctuation.separator.upl"
    },
    {
      "match": "\\b(while|if|else|for|match|catch|in)\\b",
      "name": "keyword.control.upl"
    },
    {
      "match": "\\b(@)(\\w+|\\(\\w+(,\\w+)*\\))",
      "captures": {
        "1": {"name": "keyword.other.separator.upl"},
        "2": {"name": "variable.parameter.type.upl"}
      }
    },
    {
      "match": "\\b(int|rat|float|bool|string|set|list|bag|option|any|exn|empty)\\b",
      "name": "entity.name.type.upl"
    },
    {
      "match": "\\b(true|false|univ)\\b",
      "name": "constant.language.upl"
    },
    {
      "match": "\\b_\\b",
      "name": "variable.language.upl"
    },
    {
      "match": "(_prefix_|_infix_|_circumfix_|_postfix_|_applyfix_|_bindfix_)(\\S+)",
      "captures": {
        "1": {"name": "keyword.other.fixity.upl"},
        "2": {"name": "entity.name.function.operator.upl"}
      }
    },
    {
      "match": "\\b(prefix|infix|circumfix|postfix|applyfix|bindfix)\\s+(\\S+)",
      "captures": {
        "1": {"name": "keyword.other.fixity.upl"},
        "2": {"name": "entity.name.function.operator.upl"}
      }
    },
    {
      "match": "\\b(module|theory)\\s+(\\w+)\\s*{",
      "captures": {
        "1": {"name": "storage.type.module.upl"},
        "2": {"name": "entity.name.class.upl"}
      }
    },
    {
      "match": "\\b(var|val)\\b",
      "name": "storage.type.variable.upl"
    },
    {
      "match": "\\b(type)\\s+(\\w+)",
      "captures": {
        "1": {"name": "storage.type.type.upl"},
        "2": {"name": "entity.name.type.upl"}
      }
    },
    {
      "match": "\\b(include|realize)\\s+(\\w+)",
      "captures": {
        "1": {"name": "keyword.control.import.upl"},
        "2": {"name": "entity.name.class.upl"}
      }
    },
    {
      "match": "[a-zA-Z][a-zA-Z_0-9]*",
      "name": "variable.other.upl"
    }
  ]
}